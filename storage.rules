rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function isSignedIn() {
      return request.auth != null;
    }

    function ownsTask(taskId) {
      return isSignedIn()
        && firestore.get(/databases/(default)/documents/tasks/$(taskId)).data.ownerUid == request.auth.uid;
    }

    // Task files, memo files, need files
    match /tasks/{taskId}/{allPaths=**} {
      allow read, write: if ownsTask(taskId);
    }

    match /memos/{taskId}/{allPaths=**} {
      allow read, write: if ownsTask(taskId);
    }

    match /needs/{taskId}/{allPaths=**} {
      allow read, write: if ownsTask(taskId);
    }

    match /need-fulfillment/{taskId}/{allPaths=**} {
      allow read, write: if ownsTask(taskId);
    }

    // Review submission uploads
    match /review-submissions/{taskId}/{allPaths=**} {
      allow read, write: if ownsTask(taskId);
    }

    // Permanent resources
    match /permanentFiles/{allPaths=**} {
      allow read, write: if isSignedIn();
    }

    // Deny everything else by default
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
