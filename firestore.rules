rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isTaskOwnerByUid() {
      return isSignedIn() && resource.data.ownerUid == request.auth.uid;
    }

    function isTaskOwnerByUidOnCreate() {
      return isSignedIn() && request.resource.data.ownerUid == request.auth.uid;
    }

    function canClaimLegacyTaskOwnership() {
      return isSignedIn()
        && !("ownerUid" in resource.data)
        && request.resource.data.ownerUid == request.auth.uid
        && request.resource.data.diff(resource.data).changedKeys().hasOnly(["ownerUid"]);
    }

    // TaskLedger collections used by the app
    match /tasks/{docId} {
      allow read: if isSignedIn();
      allow create: if isTaskOwnerByUidOnCreate();
      allow update: if isTaskOwnerByUid() || canClaimLegacyTaskOwnership();
      allow delete: if isTaskOwnerByUid();
    }

    match /notifications/{docId} {
      allow read, write: if isSignedIn();
    }

    match /messages/{docId} {
      allow read, write: if isSignedIn();
    }

    match /chatHistory/{docId} {
      allow read, write: if isSignedIn();
    }

    match /knowledgeBase/{docId} {
      allow read, write: if isSignedIn();
    }

    match /deadlinePushRequests/{docId} {
      allow read, write: if isSignedIn();
    }

    match /permanentFiles/{docId} {
      allow read, write: if isSignedIn();
    }

    // Deny everything else by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
